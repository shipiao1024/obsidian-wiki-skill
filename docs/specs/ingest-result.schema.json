{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "IngestResult",
  "description": "JSON contract for the L3 main orchestrator output (wiki_ingest.py). Returned as top-level JSON after a complete ingest run.",
  "type": "object",
  "required": ["ingested"],
  "properties": {
    "ingested": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["title", "slug", "status", "compile_mode", "compile_reason", "skip_reason", "quality", "delta_outputs"],
        "properties": {
          "title": { "type": "string" },
          "slug": { "type": "string" },
          "status": { "type": "string", "enum": ["ingested", "skipped"] },
          "compile_mode": { "type": "string", "enum": ["heuristic", "llm", "llm-v2", "skipped"] },
          "compile_reason": { "type": "string" },
          "skip_reason": { "type": "string" },
          "quality": { "type": "string" },
          "delta_outputs": { "type": "string", "description": "Comma-separated delta output filenames" }
        }
      },
      "description": "Per-article ingest results"
    },
    "collections": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "source_kind": { "type": "string" },
          "source_url": { "type": "string" },
          "collection_status": { "type": "string", "enum": ["ok", "partial", "paused", "failed"] },
          "collection_reason": { "type": "string" },
          "job_path": { "type": "string" },
          "cooldown_until": { "type": "string" }
        }
      },
      "description": "Collection-level status (only present for video playlist/channel ingests)"
    }
  }
}